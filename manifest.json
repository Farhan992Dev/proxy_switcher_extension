{
  "manifest_version": 3,
  "name": "Proxy Switcher",
  "version": "1.0",
  "description": "Route specific sites through your HTTP proxy",
  "permissions": [
    "proxy",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
